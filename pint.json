{
    "preset": "laravel",
    "rules": {
        "binary_operator_spaces": {
            "default": "single_space",
            "operators": {
                "=":  "align_single_space_minimal",
                ".=": "align_single_space_minimal",
                "+=": "align_single_space_minimal",
                "=>": "align_single_space_minimal"
            }
        },
        "concat_space": {
            "spacing": "one"
        },
        "php_unit_method_casing": {
            "case": "camel_case"
        },
        "no_multiline_whitespace_around_double_arrow": false
    }
}
