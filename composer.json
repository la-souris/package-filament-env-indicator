{
  "name": "la-souris/filament-env-indicator",
  "description": "Filament v5 plugin to change the header color according to environment",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "filament/support": "^5.6",
    "filament/filament": "^5.6"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "LaSouris\\FillamentEnvIndicator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LaSouris\\FillamentEnvIndicator\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "LaSouris\\FillamentEnvIndicator\\EnvIndicatorServiceProvider"
      ]
    }
  }
}
